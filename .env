# Token secreto que debe ir en la URL del QR
# Ejemplo de URL del QR: https://tu-app.vercel.app/?token=expo-paola-2026
SUBMIT_TOKEN=expo-nombre-sala
# En producción, descomenta esto con tu dominio de Vercel:
ALLOWED_ORIGIN=https://mapaexpopaodeploy.vercel.app/

# VITE_API_BASE no se necesita en dev (Vite lo proxea)
# En producción (Vercel), define esta variable apuntando al backend:
VITE_API_BASE=mapaexpopaodeploy-production.up.railway.app/api
